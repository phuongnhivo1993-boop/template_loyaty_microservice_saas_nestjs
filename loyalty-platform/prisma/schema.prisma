generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  HOST
  ADMIN
  STAFF
  MEMBER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_KYC
}

model Host {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants Tenant[]

  @@map("hosts")
}

model Tenant {
  id        String       @id @default(uuid())
  name      String
  domain    String       @unique
  subdomain String?      @unique
  email     String
  phone     String?
  address   String?
  logo      String?
  status    TenantStatus @default(ACTIVE)
  hostId    String
  host      Host         @relation(fields: [hostId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users    User[]
  members  Member[]
  tiers    Tier[]
  campaigns    Campaign[]
  rewards      Reward[]
  vouchers     Voucher[]
  promotions   Promotion[]
  badges       Badge[]
  missions     Mission[]
  notificationLogs NotificationLog[]
  notificationTemplates NotificationTemplate[]
  pointEarningRules    PointEarningRule[]
  stores       Store[]
  cashbackConfigs      CashbackConfig[]
  partnerBrands        PartnerBrand[]
  webhookEndpoints     WebhookEndpoint[]
  giftCards            GiftCard[]
  productCategories    ProductCategory[]
  products             Product[]
  orders               Order[]
  coupons              Coupon[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  phone     String?
  role      UserRole @default(MEMBER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("users")
}

model Tier {
  id               String   @id @default(uuid())
  name             String
  minPoints        Int      @default(0)
  maxPoints        Int      @default(999999)
  pointsMultiplier Float    @default(1.0)
  benefits         String?
  color            String?
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  members Member[]

  @@map("tiers")
}

model Member {
  id           String       @id @default(uuid())
  email        String       @unique
  password     String?      // null for OAuth/phone-registered members
  fullName     String
  phone        String?
  avatar       String?
  birthday     DateTime?
  tags         String[]
  status       MemberStatus @default(ACTIVE)
  kycVerified  Boolean      @default(false)
  totalPoints  Int          @default(0)
  availablePoints Int       @default(0)
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  tierId       String?
  tier         Tier?        @relation(fields: [tierId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  pointTransactions  PointTransaction[]
  referralsGiven     Referral[]          @relation("ReferralGiven")
  referralsReceived  Referral[]          @relation("ReferralReceived")
  memberVouchers     MemberVoucher[]
  dailyCheckins      DailyCheckin[]
  cashbackTransactions CashbackTransaction[]
  memberGiftCards    MemberGiftCard[]
  feedback           MemberFeedback[]
  orders             Order[]
  couponUsages       CouponUsage[]

  @@index([tenantId])
  @@index([status])
  @@index([tierId])
  @@index([createdAt])
  @@map("members")
}

model PointTransaction {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  type      String   // EARN, BURN, EXPIRE, ADJUST
  amount    Int
  balance   Int
  reason    String?
  reference String?
  createdAt DateTime @default(now())

  @@index([memberId])
  @@index([type])
  @@index([createdAt])
  @@map("point_transactions")
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  status      String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED, ENDED
  budget      Float?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("campaigns")
}

model Reward {
  id             String   @id @default(uuid())
  name           String
  description    String?
  type           String   // voucher, gift, cashback, coupon
  pointsRequired Int
  quantity       Int      @default(0)
  imageUrl       String?
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@map("rewards")
}

model Voucher {
  id        String   @id @default(uuid())
  code      String   @unique
  type      String   // discount, cashback, gift
  value     Float
  maxUsage  Int?
  usedCount Int      @default(0)
  expiresAt DateTime?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberVouchers MemberVoucher[]

  @@index([tenantId])
  @@map("vouchers")
}

model MemberVoucher {
  id         String   @id @default(uuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  voucherId  String
  voucher    Voucher  @relation(fields: [voucherId], references: [id])
  qrCode     String   @unique
  redeemed   Boolean  @default(false)
  redeemedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([memberId])
  @@index([voucherId])
  @@index([qrCode])
  @@index([redeemed])
  @@map("member_vouchers")
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String   // email, sms, push
  subject   String
  content   String
  variables String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

model NotificationLog {
  id         String   @id @default(uuid())
  templateId String
  recipient  String
  channel    String   // email, sms, push
  subject    String?
  content    String?
  status     String   @default("PENDING") // PENDING, SENT, FAILED
  sentAt     DateTime?
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt  DateTime @default(now())

  @@map("notification_logs")
}

model Promotion {
  id          String   @id @default(uuid())
  name        String
  description String?
  priority    Int      @default(0)
  status      String   @default("ACTIVE")
  conditions  Json?
  actions     Json?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("promotions")
}

model Referral {
  id          String   @id @default(uuid())
  code        String   @unique
  referrerId  String
  referrer    Member   @relation("ReferralGiven", fields: [referrerId], references: [id])
  refereeId   String?
  referee     Member?  @relation("ReferralReceived", fields: [refereeId], references: [id])
  status      String   @default("PENDING") // PENDING, CONVERTED, REWARDED
  rewardGiven Boolean  @default(false)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([referrerId])
  @@index([status])
  @@map("referrals")
}

model Badge {
  id          String   @id @default(uuid())
  name        String
  description String?
  iconUrl     String?
  criteria    Json?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("badges")
}

model Mission {
  id          String   @id @default(uuid())
  name        String
  description String?
  pointsReward Int     @default(0)
  criteria    Json?
  startDate   DateTime?
  endDate     DateTime?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("missions")
}

model Settings {
  id        String   @id @default(uuid())
  scope     String   // "platform" or "tenant"
  scopeId   String   @default("_platform") // tenantId if scope=tenant, "_platform" if scope=platform
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, scopeId, key])
  @@index([scope, scopeId])
  @@map("settings")
}

model DailyCheckin {
  id        String   @id @default(uuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  date      DateTime @default(now())
  streak    Int      @default(1)
  pointsAwarded Int  @default(0)

  @@unique([memberId, date])
  @@index([memberId])
  @@map("daily_checkins")
}

model PointEarningRule {
  id             String   @id @default(uuid())
  name           String
  description    String?
  pointsPerUnit  Float    @default(1.0)
  minAmount      Float?
  maxAmount      Float?
  category       String?
  status         String   @default("ACTIVE")
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@map("point_earning_rules")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String   // CREATE, UPDATE, DELETE
  userId     String?
  userEmail  String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

model Store {
  id             String      @id @default(uuid())
  name           String
  code           String      @unique
  address        String?
  phone          String?
  email          String?
  latitude       Float?
  longitude      Float?
  openingHours   Json?
  status         StoreStatus @default(ACTIVE)
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  storeStaff StoreStaff[]
  orders     Order[]

  @@index([tenantId])
  @@index([code])
  @@index([status])
  @@map("stores")
}

model StoreStaff {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  userId    String?
  name      String
  phone     String
  pinCode   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([phone])
  @@map("store_staff")
}

model CashbackConfig {
  id               String   @id @default(uuid())
  name             String
  description      String?
  rate             Float    @default(0.01)
  minAmount        Float?
  maxAmount        Float?
  minPointsBalance Int?
  startDate        DateTime?
  endDate          DateTime?
  status           String   @default("ACTIVE")
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@map("cashback_configs")
}

model CashbackTransaction {
  id            String   @id @default(uuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id])
  type          String   // EARN, REDEEM, EXPIRE
  amount        Float
  referenceId   String?  // link to order/transaction
  description   String?
  balance       Float
  tenantId      String
  createdAt     DateTime @default(now())

  @@index([memberId])
  @@index([type])
  @@index([createdAt])
  @@map("cashback_transactions")
}

model PartnerBrand {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  description    String?
  logo           String?
  website        String?
  contactEmail   String?
  contactPhone   String?
  commissionRate Float    @default(0.05)
  status         String   @default("ACTIVE")
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  partnerRewards PartnerReward[]

  @@index([tenantId])
  @@index([code])
  @@map("partner_brands")
}

model PartnerReward {
  id             String   @id @default(uuid())
  brandId        String
  brand          PartnerBrand @relation(fields: [brandId], references: [id])
  name           String
  description    String?
  type           String   // voucher, gift, discount
  value          Float
  pointsRequired Int
  quantity       Int      @default(0)
  imageUrl       String?
  startDate      DateTime?
  endDate        DateTime?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([brandId])
  @@map("partner_rewards")
}

model WebhookEndpoint {
  id          String   @id @default(uuid())
  name        String
  url         String
  secret      String?
  events      String[] // e.g. ["point.earned", "member.created", "voucher.redeemed"]
  active      Boolean  @default(true)
  lastTriggeredAt DateTime?
  failureCount Int     @default(0)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventLogs WebhookEventLog[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

model WebhookEventLog {
  id           String   @id @default(uuid())
  endpointId   String
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id])
  event        String
  payload      Json?
  responseCode Int?
  responseBody String?
  success      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([endpointId])
  @@index([success])
  @@map("webhook_event_logs")
}

model WebSocketEventLog {
  id        String   @id @default(uuid())
  event     String
  room      String?
  payload   Json?
  memberId  String?
  tenantId  String?
  createdAt DateTime @default(now())

  @@index([room, createdAt])
  @@index([memberId, createdAt])
  @@index([tenantId, createdAt])
  @@map("websocket_event_logs")
}

model GiftCard {
  id          String   @id @default(uuid())
  code        String   @unique
  initialValue Float
  balance     Float
  type        String   // physical, digital
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED, REDEEMED, DISABLED
  expiresAt   DateTime?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberGiftCards MemberGiftCard[]

  @@index([tenantId])
  @@index([code])
  @@map("gift_cards")
}

model MemberGiftCard {
  id         String   @id @default(uuid())
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id])
  balance    Float
  createdAt  DateTime @default(now())

  @@index([memberId])
  @@map("member_gift_cards")
}

model MemberFeedback {
  id          String   @id @default(uuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  entityType  String   // reward, voucher, campaign, store
  entityId    String
  rating      Int      // 1-5
  content     String?
  status      String   @default("PUBLISHED") // PENDING, PUBLISHED, HIDDEN
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memberId])
  @@index([entityType, entityId])
  @@index([rating])
  @@map("member_feedback")
}

model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  slug      String
  description String?
  icon      String?
  sortOrder Int       @default(0)
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  slug        String
  description String?
  price       Float
  compareAtPrice Float?
  costPrice   Float?
  imageUrl    String?
  unit        String    @default("piece")
  stock       Int       @default(0)
  sku         String?
  barcode     String?
  status      String    @default("ACTIVE") // ACTIVE, INACTIVE, OUT_OF_STOCK
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orderItems OrderItem[]

  @@unique([slug, tenantId])
  @@unique([sku, tenantId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
  @@map("products")
}

model Order {
  id            String      @id @default(uuid())
  orderCode     String      @unique
  memberId      String
  member        Member      @relation(fields: [memberId], references: [id])
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  storeId       String?
  store         Store?      @relation(fields: [storeId], references: [id])
  status        OrderStatus @default(PENDING)
  subtotal      Float
  discount      Float       @default(0)
  shippingFee   Float       @default(0)
  tax           Float       @default(0)
  total         Float
  pointsEarned  Int         @default(0)
  pointsUsed    Int         @default(0)
  couponCode    String?
  notes         String?
  shippingAddress Json?
  paymentMethod String?
  paidAt        DateTime?
  deliveredAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  statusHistory Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items OrderItem[]
  couponUsages CouponUsage[]

  @@index([memberId])
  @@index([tenantId])
  @@index([orderCode])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String  // snapshot of product name at time of order
  price     Float   // snapshot of unit price
  quantity  Int
  subtotal  Float

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Coupon {
  id          String   @id @default(uuid())
  code        String
  type        String   // PERCENTAGE, FIXED
  value       Float    // discount % (10 = 10%) or fixed amount (50000 = 50k VND)
  minAmount   Float?   // minimum order total to apply
  maxDiscount Float?   // max discount for percentage type
  maxUsage    Int?     // max total uses (null = unlimited)
  usedCount   Int      @default(0)
  maxUsagePerMember Int? @default(1) // max uses per member (null = unlimited)
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("ACTIVE") // ACTIVE, DISABLED, EXPIRED
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usages CouponUsage[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([status])
  @@index([code])
  @@map("coupons")
}

model CouponUsage {
  id             String   @id @default(uuid())
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id])
  memberId       String
  member         Member   @relation(fields: [memberId], references: [id])
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  discountAmount Float
  createdAt      DateTime @default(now())

  @@index([couponId])
  @@index([memberId])
  @@index([orderId])
  @@map("coupon_usages")
}
