          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "targets": [
          {
            "expr": "db_connections_active{job=~\"api-gateway|membership-service|loyalty-service|campaign-service|reward-service|referral-service|voucher-service|promotion-service|gamification-service|notification-service|analytics-service|customer360-service\"}",
            "legendFormat": "{{ job }}",
