      {
        "id": 14,
        "title": "Elasticsearch Health",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 8, "y": 20 },
        "description": "Elasticsearch cluster status",
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
