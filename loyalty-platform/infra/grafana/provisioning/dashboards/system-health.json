{
  "__description": "System Health Dashboard - Loyalty Platform",
  "dashboard": {
    "title": "System Health",
    "description": "Comprehensive system health monitoring for all loyalty platform microservices",
    "tags": ["loyalty", "system-health", "microservices"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "panels": [
      {
        "id": 1,
        "title": "Service Uptime",
        "type": "stat",
        "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
        "description": "Up/down status of all 12 microservices",
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["lastNotNull"], "values": false, "fields": "" },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "color": {
              "mode": "thresholds"
            },
            "mappings": [
              { "type": "value", "value": "1", "text": "UP", "color": "green" },
              { "type": "value", "value": "0", "text": "DOWN", "color": "red" }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          },
          "overrides": []
        },
        "targets": [
          {
            "expr": "up{job=~\"api-gateway|membership-service|loyalty-service|campaign-service|reward-service|referral-service|voucher-service|promotion-service|gamification-service|notification-service|analytics-service|customer360-service\"}",
            "legendFormat": "{{ job }}",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          }
        ],
        "datasource": { "uid": "prometheus" },
        "type": "stat"
      },
      {
        "id": 2,
        "title": "API Gateway - Requests per second",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 12, "y": 0 },
        "description": "Incoming request rate through the API gateway",
        "options": {
          "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisCenteredZero": false,
              "axisColorMode": "text",
              "axisLabel": "",
              "axisPlacement": "auto",
              "barAlignment": 0,
              "drawStyle": "line",
              "fillOpacity": 10,
              "gradientMode": "none",
              "hideFrom": { "legend": false, "tooltip": false, "viz": false },
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "pointSize": 3,
              "scaleDistribution": { "type": "linear" },
              "showPoints": "never",
              "spanNulls": true,
              "stacking": { "group": "A", "mode": "none" },
              "thresholdsStyle": { "mode": "off" }
            },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{job=\"api-gateway\"}[5m]))",
            "legendFormat": "Total Requests",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          },
          {
            "expr": "sum(rate(http_requests_total{job=\"api-gateway\",status=~\"5..\"}[5m]))",
            "legendFormat": "5xx Errors",
            "interval": "",
            "intervalFactor": 1,
            "refId": "B"
          }
        ],
        "datasource": { "uid": "prometheus" }
      },
      {
        "id": 3,
        "title": "CPU Usage per Service",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
        "description": "CPU cores used per microservice",
        "options": {
          "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisCenteredZero": false,
              "axisColorMode": "text",
              "axisLabel": "CPU cores",
              "axisPlacement": "auto",
              "barAlignment": 0,
              "drawStyle": "line",
              "fillOpacity": 10,
              "gradientMode": "none",
              "hideFrom": { "legend": false, "tooltip": false, "viz": false },
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "pointSize": 3,
              "scaleDistribution": { "type": "linear" },
              "showPoints": "never",
              "spanNulls": true,
              "stacking": { "group": "A", "mode": "none" },
              "thresholdsStyle": { "mode": "off" }
            },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=~\"api-gateway|membership-service|loyalty-service|campaign-service|reward-service|referral-service|voucher-service|promotion-service|gamification-service|notification-service|analytics-service|customer360-service\"}[5m])",
            "legendFormat": "{{ job }}",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          }
        ],
        "datasource": { "uid": "prometheus" }
      },
      {
        "id": 4,
        "title": "Memory Usage per Service",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
        "description": "Resident memory usage per microservice",
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisCenteredZero": false,
              "axisColorMode": "text",
              "axisLabel": "",
              "axisPlacement": "auto",
              "barAlignment": 0,
              "drawStyle": "line",
              "fillOpacity": 10,
              "gradientMode": "none",
              "hideFrom": { "legend": false, "tooltip": false, "viz": false },
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "pointSize": 3,
              "scaleDistribution": { "type": "linear" },
              "showPoints": "never",
              "spanNulls": true,
              "stacking": { "group": "A", "mode": "none" },
              "thresholdsStyle": { "mode": "off" }
            },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
          },
          "overrides": []
        },
        "options": {
          "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=~\"api-gateway|membership-service|loyalty-service|campaign-service|reward-service|referral-service|voucher-service|promotion-service|gamification-service|notification-service|analytics-service|customer360-service\"}",
            "legendFormat": "{{ job }}",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          }
        ],
        "datasource": { "uid": "prometheus" }
      },
      {
        "id": 5,
        "title": "API Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
        "description": "HTTP 5xx error rate per service",
        "fieldConfig": {
          "defaults": {
            "unit": "cps",
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisCenteredZero": false,
              "axisColorMode": "text",
              "axisLabel": "",
              "axisPlacement": "auto",
              "barAlignment": 0,
              "drawStyle": "line",
              "fillOpacity": 20,
              "gradientMode": "none",
              "hideFrom": { "legend": false, "tooltip": false, "viz": false },
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "pointSize": 3,
              "scaleDistribution": { "type": "linear" },
              "showPoints": "never",
              "spanNulls": true,
              "stacking": { "group": "A", "mode": "none" },
              "thresholdsStyle": { "mode": "line" }
            },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }
          },
          "overrides": []
        },
        "options": {
          "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (job)",
            "legendFormat": "{{ job }}",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          }
        ],
        "datasource": { "uid": "prometheus" }
      },
      {
        "id": 6,
        "title": "API Response Time (p50)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
        "description": "Median API response time per service",
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": { "mode": "palette-classic" },
            "custom": {
              "axisCenteredZero": false,
              "axisColorMode": "text",
              "axisLabel": "",
              "axisPlacement": "auto",
              "barAlignment": 0,
              "drawStyle": "line",
              "fillOpacity": 10,
              "gradientMode": "none",
              "hideFrom": { "legend": false, "tooltip": false, "viz": false },
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "pointSize": 3,
              "scaleDistribution": { "type": "linear" },
              "showPoints": "never",
              "spanNulls": true,
              "stacking": { "group": "A", "mode": "none" },
              "thresholdsStyle": { "mode": "line" }
            },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1 }] }
          },
          "overrides": []
        },
        "options": {
          "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
          "tooltip": { "mode": "multi", "sort": "desc" }
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
            "legendFormat": "{{ job }}",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          }
        ],
        "datasource": { "uid": "prometheus" }
      },
      {
        "id": 7,
        "title": "API Response Time (p95)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 10 },
        "description": "95th percentile API response time per service",
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": { "mode": "palette-classic" },
