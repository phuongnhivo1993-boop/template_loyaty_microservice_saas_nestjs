          },
          "overrides": []
        },
        "targets": [
          {
            "expr": "sum(rate(db_query_duration_seconds_count[5m])) by (job)",
            "legendFormat": "{{ job }}",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          }
        ],
        "datasource": { "uid": "prometheus" }
      },
      {
        "id": 12,
        "title": "Request Latency by Endpoint (p95)",
        "type": "bargauge",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
        "description": "p95 latency per endpoint handler",
        "options": {
          "displayMode": "gradient",
          "legend": { "calcs": [], "displayMode": "hidden", "placement": "bottom", "showLegend": false },
          "minVizHeight": 10,
          "minVizWidth": 0,
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "showUnfilled": true,
          "tooltip": { "mode": "single", "sort": "none" }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "color": { "mode": "thresholds" },
            "mappings": [],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 2 }] }
          },
          "overrides": []
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"api-gateway\"}[5m])) by (le, handler))",
            "legendFormat": "{{ handler }}",
            "interval": "",
            "intervalFactor": 1,
            "refId": "A"
          }
        ],
        "datasource": { "uid": "prometheus" }
      },
      {
        "id": 13,
