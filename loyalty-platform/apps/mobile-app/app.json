{
  "expo": {
    "name": "Loyalty Platform",
    "slug": "loyalty-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": { "backgroundColor": "#1e293b" },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.loyalty.mobile" },
    "android": { "adaptiveIcon": { "backgroundColor": "#1e293b" }, "package": "com.loyalty.mobile" },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ]
  }
}
