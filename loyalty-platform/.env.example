# =============================================================================
# Loyalty Platform - Environment Configuration
# =============================================================================

# --- API Gateway ---
API_GATEWAY_PORT=3001

# --- Microservice Ports ---
MEMBERSHIP_SERVICE_PORT=3002
LOYALTY_SERVICE_PORT=3003
CAMPAIGN_SERVICE_PORT=3004
REWARD_SERVICE_PORT=3005
REFERRAL_SERVICE_PORT=3006
VOUCHER_SERVICE_PORT=3007
PROMOTION_SERVICE_PORT=3008
GAMIFICATION_SERVICE_PORT=3009
NOTIFICATION_SERVICE_PORT=3010
ANALYTICS_SERVICE_PORT=3011
CUSTOMER360_SERVICE_PORT=3012

# --- PostgreSQL (6 instances, isolated per service group) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=loyalty
POSTGRES_PASSWORD=loyalty_secret
POSTGRES_DB=loyalty_api_gateway

POSTGRES_MEMBERSHIP_HOST=localhost
POSTGRES_MEMBERSHIP_PORT=5433
POSTGRES_CAMPAIGN_HOST=localhost
POSTGRES_CAMPAIGN_PORT=5434
POSTGRES_NOTIFICATION_HOST=localhost
POSTGRES_NOTIFICATION_PORT=5435
POSTGRES_ANALYTICS_HOST=localhost
POSTGRES_ANALYTICS_PORT=5436
POSTGRES_GAMIFICATION_HOST=localhost
POSTGRES_GAMIFICATION_PORT=5437

# Per-service database URLs (dedicated instances)
MEMBERSHIP_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5433/loyalty_membership
LOYALTY_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5433/loyalty_loyalty
CAMPAIGN_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5434/loyalty_campaign
REWARD_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5434/loyalty_reward
VOUCHER_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5432/loyalty_voucher
REFERRAL_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5437/loyalty_referral
PROMOTION_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5437/loyalty_promotion
GAMIFICATION_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5437/loyalty_gamification
NOTIFICATION_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5435/loyalty_notification
ANALYTICS_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5436/loyalty_analytics
CUSTOMER360_DB_URL=postgresql://loyalty:loyalty_secret@localhost:5436/loyalty_customer360

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Kafka ---
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=loyalty-platform

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost:9003
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret_123
MINIO_BUCKET=loyalty-assets

# --- Keycloak (SSO) ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=loyalty
KEYCLOAK_CLIENT_ID=loyalty-backend
KEYCLOAK_CLIENT_SECRET=keycloak_secret

# --- ClickHouse (Analytics) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9002
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200

# --- JWT ---
JWT_SECRET=loyalty_jwt_secret_key_change_in_production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# --- Prisma ---
DATABASE_URL=postgresql://loyalty:loyalty_secret@localhost:5432/loyalty_platform

# --- App ---
NODE_ENV=development
