# =============================================================================
# Loyalty Platform - Environment Configuration (Template)
# Copy this file to .env and fill in your values
# =============================================================================

# --- API Gateway ---
API_GATEWAY_PORT=3001
# Enable Swagger/OpenAPI docs (default: true in dev, false in prod)
SWAGGER_ENABLED=true

# --- Microservice Ports ---
MEMBERSHIP_SERVICE_PORT=3002
LOYALTY_SERVICE_PORT=3003
CAMPAIGN_SERVICE_PORT=3004
REWARD_SERVICE_PORT=3005
REFERRAL_SERVICE_PORT=3006
VOUCHER_SERVICE_PORT=3007
PROMOTION_SERVICE_PORT=3008
GAMIFICATION_SERVICE_PORT=3009
NOTIFICATION_SERVICE_PORT=3010
ANALYTICS_SERVICE_PORT=3011
CUSTOMER360_SERVICE_PORT=3012

# --- PostgreSQL (6 instances, isolated per service group) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=loyalty_api_gateway

POSTGRES_MEMBERSHIP_HOST=localhost
POSTGRES_MEMBERSHIP_PORT=5433
POSTGRES_CAMPAIGN_HOST=localhost
POSTGRES_CAMPAIGN_PORT=5434
POSTGRES_NOTIFICATION_HOST=localhost
POSTGRES_NOTIFICATION_PORT=5435
POSTGRES_ANALYTICS_HOST=localhost
POSTGRES_ANALYTICS_PORT=5436
POSTGRES_GAMIFICATION_HOST=localhost
POSTGRES_GAMIFICATION_PORT=5437

# Per-service database URLs (dedicated instances)
MEMBERSHIP_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5433/loyalty_membership
LOYALTY_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5433/loyalty_loyalty
CAMPAIGN_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5434/loyalty_campaign
REWARD_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5434/loyalty_reward
VOUCHER_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/loyalty_voucher
REFERRAL_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5437/loyalty_referral
PROMOTION_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5437/loyalty_promotion
GAMIFICATION_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5437/loyalty_gamification
NOTIFICATION_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5435/loyalty_notification
ANALYTICS_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5436/loyalty_analytics
CUSTOMER360_DB_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5436/loyalty_customer360

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# --- Kafka ---
KAFKA_BROKER=localhost:9092
KAFKA_CLIENT_ID=loyalty-platform

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost:9003
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=loyalty-assets

# --- Keycloak (SSO) ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=loyalty
KEYCLOAK_CLIENT_ID=loyalty-backend
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# --- ClickHouse (Analytics) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9002
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200

# --- JWT ---
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# --- SMTP (Email Delivery) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Loyalty Platform
SMTP_FROM_EMAIL=noreply@loyalty-platform.com

# --- Encryption ---
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY

# --- Prisma ---
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@localhost:5432/loyalty_platform

# --- Stripe ---
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
# Stripe Price IDs for each plan (create products/prices in Stripe dashboard first)
STRIPE_PRICE_FREE=YOUR_STRIPE_PRICE_ID_FREE
STRIPE_PRICE_STARTER=YOUR_STRIPE_PRICE_ID_STARTER
STRIPE_PRICE_PROFESSIONAL=YOUR_STRIPE_PRICE_ID_PROFESSIONAL
STRIPE_PRICE_ENTERPRISE=YOUR_STRIPE_PRICE_ID_ENTERPRISE

# --- Seed Credentials (set these to override random seed passwords) ---
# SEED_HOST_PASSWORD=YourHost@2024!
# SEED_ADMIN_PASSWORD=YourAdmin@2024!
# SEED_MEMBER_PASSWORD=YourMember@2024!

# --- App ---
NODE_ENV=development
# CORS_ORIGIN=http://localhost:3001,http://localhost:3002
# LOG_LEVEL=debug
